{
  "name": "auto-traffic",
  "version": "1.0.0",
  "description": "Auto Traffic - Electron + Playwright",
  "main": "src/main/main.js",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "dev": "ELECTRON_RUN_AS_NODE= electron . --dev",
    "build": "electron-builder",
    "dist": "electron-builder --publish=never",
    "dist:win": "node scripts/close-built-app.js && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --publish=never"
  },
  "keywords": [
    "automation",
    "auto-traffic",
    "electron",
    "playwright"
  ],
  "author": "Auto Traffic",
  "license": "MIT",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "https-proxy-agent": "^9.0.0",
    "playwright": "^1.51.0",
    "uuid": "^13.0.0"
  },
  "overrides": {
    "rimraf": "^6.1.3",
    "glob": "^10.4.5",
    "tar": "^7.4.3",
    "inflight": "npm:lru-cache",
    "npmlog": "npm:winlog",
    "are-we-there-yet": "npm:progress",
    "@npmcli/move-file": "npm:@npmcli/fs",
    "boolean": "npm:semver",
    "gauge": "npm:cli-progress"
  },
  "build": {
    "appId": "com.autotraffic.app",
    "productName": "Auto Traffic",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "data/**/*",
      "assets/**/*",
      "CapSolver.Browser.Extension*/**",
      "!data/accounts.json",
      "!data/proxies.json",
      "!data/capsolver-settings.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/auto-traffic-logo.ico",
      "signAndEditExecutable": false,
      "signtoolOptions": {
        "sign": null
      }
    },
    "nsis": {
      "installerIcon": "assets/auto-traffic-logo.ico",
      "uninstallerIcon": "assets/auto-traffic-logo.ico"
    },
    "npmRebuild": false,
    "electronFuses": {
      "enableEmbeddedAsarIntegrityValidation": false
    }
  }
}